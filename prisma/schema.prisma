generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id       String @id @default(cuid())
    email    String @unique
    name     String
    password String
    notes    Note[]
}

model Note {
    id        String   @id @default(cuid())
    title     String
    content   String
    userId    String
    user      User     @relation(fields: [userId], references: [id])
    tags      Tag[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Tag {
    id    String @id @default(cuid())
    name  String @unique
    color String
    notes Note[]
}
